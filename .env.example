# Copy to .env.local and fill in. Never commit real secrets (.env* is gitignored).
# Set the same vars in Vercel → Project → Settings → Environment Variables.

# Session encryption key. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Set to true on Vercel (and fine locally). Lets Auth.js trust the deploy host.
AUTH_TRUST_HOST=true

# Google OAuth 2.0 Web client (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-prod-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth App (Settings → Developer settings → OAuth Apps → New).
# Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github   (dev)
#   https://<your-prod-domain>/api/auth/callback/github   (prod; may need a separate app)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Neon Postgres pooled connection string (Neon dashboard → Connection Details).
DATABASE_URL=
